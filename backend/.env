# Sao chép thành .env để chạy local
DEBUG=True
SECRET_KEY=change-me-to-a-50-char-random-string
JWT_SECRET_KEY=change-me-jwt-secret

# Database
DB_NAME=english_study_db
DB_USER=postgres
DB_PASSWORD=1123
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (danh sách frontend, cách nhau dấu phẩy)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# AWS S3 (để trống khi dùng local storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=english-study-media
AWS_S3_REGION_NAME=ap-southeast-1

# OpenAI
OPENAI_API_KEY=

# Cookie security (True trong production HTTPS)
JWT_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
