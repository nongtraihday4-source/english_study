    {
      "level": "A1",
      "title": "Be going to: Form",
      "slug": "a1-be-going-to-form",
      "order": 22,
      "chapter": "Future",
      "description": "Be going to consists of the present continuous of the verb go (I’m going, you are going, etc.) + to-infinitive form of the main verb.",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": [
        {
          "title": "When the main verb is go",
          "formula": "",
          "explanation": "I’m going shopping this afternoon. (=I’m going to go shopping this afternoon.) We are going to Cyprus next summer. (=We are going to go to Cyprus next summer. )",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "When the main verb is go, we can exclude it if we want.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        }
      ]
    },
    {
      "level": "A1",
      "title": "Be going to: Use",
      "slug": "a1-be-going-to-use",
      "order": 23,
      "chapter": "Future",
      "description": "",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": [
        {
          "title": "Predictions",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "We use be going to to talk about something that we see is going to happen (there is present evidence).",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Don’t drive like a crazy man. We’re going to have an accident!",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "The doctor said I’m going to have a girl.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Look at those clouds. It’s going to rain.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Intentions or plans",
          "formula": "",
          "explanation": "‘Why are you undressing?’ ‘Because I’m going to go for a swim.’",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": [
            {
              "sentence": "We use be going to for intentions or plans (decisions taken before the moment of speaking).",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
