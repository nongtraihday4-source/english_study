    {
      "level": "A1",
      "title": "Form",
      "slug": "a1-form",
      "order": 28,
      "chapter": "Modals, the imperative, etc .",
      "description": "The form of the verb used for the imperative is the base form of the verb (=the infinitive without to). There is no subject.\nThe negative imperative is made with do not or don’t + infinitive (no subject).",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": []
    },
    {
      "level": "A1",
      "title": "Use",
      "slug": "a1-use",
      "order": 29,
      "chapter": "Modals, the imperative, etc .",
      "description": "You can use the imperative to:",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": [
        {
          "title": "Give instructions",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
