      "rules": [
        {
          "title": "Adverbs of manner: Use",
          "formula": "",
          "explanation": "It rained heavily. (=We are describing how it rained.) He always replies quickly. (=We are describing how he replies)",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "We use adverbs of manner after a verb to describe the verb. We use an adverb of manner to say how something happens or how we do something.",
              "translation": "",
