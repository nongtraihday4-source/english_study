            }
          ]
        },
        {
          "title": "Any",
          "formula": "",
          "explanation": "❗ But we use some in questions when we are asking for something, or we are offering something. Can I have some tea? (=I’m asking for some tea.) Would you like some tea? (=I’m offering you some tea.)",
          "memory_hook": "",
          "is_exception": false,
          "order": 4,
          "examples": [
            {
              "sentence": "We use any in negative sentences and questions.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "She didn’t send me any messages.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Have you got any brothers or sisters?",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        }
      ]
    },
    {
      "level": "A1",
      "title": "Grammar chart: Much, many, a lot of, a little, a few, no, any, none",
      "slug": "a1-grammar-chart-much-many-a-lot-of-a-little-a-few-no-any-none",
      "order": 52,
