    {
      "level": "A1",
      "title": "This/these= here, that/those= there",
      "slug": "a1-thisthese-here-thatthose-there",
      "order": 43,
      "chapter": "Articles, nouns, pronouns, and determiners.",
      "description": "We use this and these for things that are here (near). This is singular and these is plural. This is my new watch. These are my sisters Anna and Jenny. We use that and those for things that are there (not near). That is singular and those is plural. That man is very strange. I need those boxes over there. We can use this, that, these, those with a noun (this box, that car, etc.) or without a noun. This watch is very expensive. I like that woman in the park. Who is that? (= that person) ‘What are those?’ ‘They are old pictures.’ We use this is when we introduce people and on the telephone. Hi, this is Tim. (Tim on the telephone) Laura: ‘Hi, Sara. This is my friend Paul.’ Sara: ‘Hi, Paul. Nice to meet you.’",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": []
    },
    {
      "level": "A1",
      "title": "Possessive adjectives and subject pronouns",
      "slug": "a1-possessive-adjectives-and-subject-pronouns",
      "order": 44,
      "chapter": "Articles, nouns, pronouns, and determiners.",
      "description": "",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📦",
      "rules": [
        {
          "title": "I + verb / My + noun",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "We use subject pronoun + verb, and we use possessive adjective + noun.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "These are Susan and Thomas; they are from Ohio. And that’s their house.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I love my friend Sheila.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Possessive adjectives are always singular",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": [
            {
              "sentence": "Adjectives in English have no plural form. Possessive adjectives are always singular.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "These are their suitcases.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "These are theirs suitcases.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "It/its for things, they/their for people and things",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 3,
          "examples": [
            {
              "sentence": "We use he/his and she/her for people, and we use it/its for things. But in the plural, we use they/their for people and things.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "The hotel has its own spa. It is a relaxing place.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I like those chairs, they are beautiful. But their legs are too long.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "It’s for time and weather",
          "formula": "",
          "explanation": "‘What time is it?’ ‘It’s three o’clock.’",
          "memory_hook": "",
          "is_exception": false,
          "order": 4,
          "examples": [
            {
              "sentence": "We use it’s (=it is) to talk about the time or the weather.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "It’s very windy today, but it’s sunny.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Its or it’s?",
          "formula": "Its = possessive adjective. It’s = it is (subject + verb be)",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 5,
          "examples": [
            {
              "sentence": "Look at that dog. It’s beautiful. I like its hair.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        }
      ]
    },
