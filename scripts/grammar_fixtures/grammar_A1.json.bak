    {
      "level": "A1",
      "title": "Use the",
      "slug": "a1-use-the",
      "order": 41,
      "chapter": "Articles, nouns, pronouns, and determiners.",
      "description": "",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": [
        {
          "title": "Second mention",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "We use the when we mention something for the second time.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "A man and a woman sat in front of me. The man was British, but I think the woman wasn’t.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Specific things",
          "formula": "",
          "explanation": "‘Where are the kids?’ ‘They’re in the garden.’ (=We know which kids and which garden.) Can you open the door? (=We know which door.)",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": [
            {
              "sentence": "We use the to talk about specific things or people –when it’s clear which things or people we are talking about.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "There is only one",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 3,
          "examples": [
            {
              "sentence": "We use the when there’s only one of something.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "This company is very profitable. The manager must be really good.",
              "translation": "",
