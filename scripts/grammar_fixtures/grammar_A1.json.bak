          "title": "Was/were",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "We use was/were as the past simple forms of be. We use was for I/he/she/it and were for you/we/they.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I was at home yesterday.",
