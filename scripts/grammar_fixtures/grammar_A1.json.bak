              "highlight": ""
            },
            {
              "sentence": "She was excited about the party.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "We were tired after the excursion.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Were they at the conference?",
              "translation": "",
              "context": "",
              "highlight": ""
