    {
      "level": "A1",
      "title": "Adverbs of manner vs adjectives",
      "slug": "a1-adverbs-of-manner-vs-adjectives",
      "order": 67,
      "chapter": "Adjectives and adverbs",
      "description": "We use adjectives to describe a noun (before a noun or after the verb be), and we use adverbs of manner to describe a verb (after the verb or verb + object). Compare: Robert plays the guitar well. (=W",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "⚡",
      "rules": [
        {
          "title": "Difference",
          "formula": "",
          "explanation": "We use adjectives to describe a noun (before a noun or after the verb be), and we use adverbs of manner to describe a verb (after the verb or verb + object). Compare: Robert plays the guitar well. (=We are describing the verb, i.e. how Robert plays the guitar.) Robert is a good guitar player. (=We are describing the noun, Robert.)",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "Sara eats slowly.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Sara is a slow eater.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Adjectives ending in -ly",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": [
            {
              "sentence": "Some words end in -ly, but they are adjectives, NOT adverbs: friendly, lovely, silly. We CANNOT transform these adjectives into adverbs of manner.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        }
      ]
    },
    {
      "level": "A1",
      "title": "Comparative adjectives",
      "slug": "a1-comparative-adjectives",
      "order": 68,
      "chapter": "Adjectives and adverbs",
      "description": "We use more + adjective + than or adjective + -er + than to compare things or people. My car is more expensive than your car. I am older than my brother. In this chart, you can see when we need to use more … than or -er than and the changes in spelling.",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "🎨",
      "rules": [
        {
          "title": "Two things",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "We use the comparative form of an adjective to compare two things.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Luke is taller than Mathew.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "This armchair is more comfortable than the sofa.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Less … than",
          "formula": "When we compare two things, we can also use the form less + adjective + than (less ≠ more).",
          "explanation": "Peter is less popular than Marta. (= Marta is more popular than Peter.)",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": []
        },
        {
          "title": "Than me",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 3,
          "examples": [
            {
              "sentence": "If we use a personal pronoun after than, we need an object pronoun (me, you, him, etc.).",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "My sister is taller than me.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "His sister is more intelligent than him.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Much/a bit + more",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 4,
          "examples": [
            {
              "sentence": "Before the comparative (more or –er), we can use much (=big difference) or a bit (=small difference).",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "He’s a bit taller than me.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Switzerland is much more expensive than Italy.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        }
      ]
    },
    {
      "level": "A1",
      "title": "Common mistakes!",
      "slug": "a1-common-mistakes",
      "order": 69,
      "chapter": "Adjectives and adverbs",
      "description": "",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": [
        {
          "title": "More or -er",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "We use more or –er, but we cannot use more + -er.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "My brother is more taller than me.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "My brother is taller than me.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "More than (NOT that)",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": [
            {
              "sentence": "After a comparative adjective, we use than and NOT that.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "My brother is taller that me.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "My brother is taller than me.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Than + second element of the comparison",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 3,
          "examples": [
            {
              "sentence": "We use than + the second thing that we are comparing. When we don’t mention the second element of the comparison, we do NOT use than.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I am tall, but my brother is taller than.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I am tall, but my brother is taller.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        }
      ]
    },
    {
      "level": "A1",
