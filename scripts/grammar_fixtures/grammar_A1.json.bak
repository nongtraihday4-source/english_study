    {
      "level": "A1",
      "title": "Much/many",
      "slug": "a1-muchmany",
      "order": 53,
      "chapter": "Articles, nouns, pronouns, and determiners.",
      "description": "",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": [
        {
          "title": "Many for countable, much for uncountable in (?) (-)",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "We use much/many in negative sentences and questions. We use many before plural countable nouns and much before uncountable nouns. We don’t normally use them in affirmative sentences.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "There isn’t much coffee in the jar.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Were there many people at the party?",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "How much/how many",
          "formula": "How many books did you read last semester?",
          "explanation": "‘How much is it?’ ‘It’s 43 pounds.’ ‘How much are the trousers?’ ‘They’re 58 pounds.’",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": [
            {
              "sentence": "We use how many + plural nouns and how much + uncountable nouns to ask about quantity. You can review countable and uncountable nouns here.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "How much coffee do you drink every day?",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "We can also say How much is it? to ask about the price of an item.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        }
      ]
    },
    {
      "level": "A1",
      "title": "A lot (of)",
      "slug": "a1-a-lot-of",
      "order": 54,
      "chapter": "Articles, nouns, pronouns, and determiners.",
      "description": "",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": [
        {
          "title": "Before both countable and uncountable",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "We use a lot of before both plural countable and uncountable nouns to talk about a large quantity. We normally use a lot of in positive sentences.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "She spends a lot of time watching TV.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "We had lots of good moments together.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "We can say quite a lot of to talk about medium quantity.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "With my new job, I have quite a lot of free time.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "It is also possible to use a lot of in negative sentences and questions.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Do you eat a lot of sugar?",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I don’t read a lot of books.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Of before noun; of at the end of sentence",
          "formula": "‘How many beers did you have?’ ‘I don’t know; I had a lot.’",
          "explanation": "‘How much coffee did you have?’ ‘A lot.’",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": [
            {
              "sentence": "We must always use a lot of including of before a noun. However, we can use a lot (without of) at the end of a sentence or in short answers.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I like her a lot.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        }
      ]
    },
    {
      "level": "A1",
      "title": "A few/a little",
      "slug": "a1-a-fewa-little",
      "order": 55,
      "chapter": "Articles, nouns, pronouns, and determiners.",
      "description": "",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": [
        {
          "title": "A few for countable; a little for uncountable",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "We use a few before plural countable nouns and a little before uncountable nouns in affirmative, negative and interrogative sentences to talk about a small quantity.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I have to do a few things this afternoon.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I always put a little milk in my tea.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Not many, not much",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": [
            {
              "sentence": "We can also use not many + plural countable or not much + uncountable nouns. The meaning is similar.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I don’t have to do many things this afternoon.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I don’t put much milk in my tea.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "No/not…any/none",
          "formula": "",
          "explanation": "‘How much time do you have?’ ‘None.’",
          "memory_hook": "",
          "is_exception": false,
          "order": 3,
          "examples": [
            {
              "sentence": "When we want to talk about zero quantity, we can use no + noun or not…any + noun. The meaning is the same.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I have no time today.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I don’t have any time today.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "In short answers, we use none.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        }
      ]
    },
    {
      "level": "A1",
      "title": "Whose, possessive ‘s: Whose is this? It’s Mike’s",
      "slug": "a1-whose-possessive-s-whose-is-this-its-mikes",
      "order": 56,
      "chapter": "Articles, nouns, pronouns, and determiners.",
      "description": "We use ‘s to show that something belongs to a person (or a pet) or to talk about relationships between people. This is Peter‘s father. This is the father of Peter. Peter and Mary‘s car is red. My cat‘s ears are white. We also use the possessive ‘s to talk about shops and houses. I am at John‘s. (= at John’s house) I need to go to the chemist‘s. (= the chemist’s shop) Singular noun + ‘s Anna’s clothes, Chris’s wife, the student’s books, etc. Plural noun ending in -s + ‘ (apostrophe) The students’ books, the boys’ toys, the teachers’ lounge, etc. Irregular plural noun (NOT ending in -s) + ‘s The children’s toys, men’s clothes, etc. When one thing belongs to two or more people, add ‘s only after the last noun. Paul and Katherine’s house, Anna and George’s car, etc. When we have two or more people, and each person has one thing, we add ‘s after each person. Anna’s and George’s cars (Anna’s car and George’s car), Sally’s and Tim’s computers (Sally’s computer and Tim’s computer). We use of and NOT ‘s when we talk about things (and not people or pets). the end of the street the street‘s end a picture of the eclipse the eclipse‘s picture the man of the match the match‘s man With nouns that are used together very often, we often use them together without of and without ‘s a school bus the city centre the car key",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": [
        {
          "title": "When do we use whose?",
          "formula": "When we answer with the possessive ‘s, we can also use ‘s + noun or ‘s without a noun.",
          "explanation": "We use the question word whose to ask about possession. There are two possible forms: whose + noun whose without a noun It’s John‘s car It’s John‘s.",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "Whose car is this?",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Whose books are those?",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Whose is this car?",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Whose are those books?",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Whose is this car?",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Whose vs who’s",
          "formula": "",
          "explanation": "Whose = possession (of who) Who’s = who is",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": [
            {
              "sentence": "Whose car is this?",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Who’s car is this?",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Who’s that man in the lobby?",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Whose that man in the lobby?",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        }
      ]
    },
    {
      "level": "A1",
      "title": "There is, there are: Use",
      "slug": "a1-there-is-there-are-use",
      "order": 57,
      "chapter": "there and it",
      "description": "We use there is, there are to say that something exists. There is a lot of noise.",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": [
        {
          "title": "Where something is",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "We often use there is, there are to say where something is.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "There is a good restaurant at the end of the street.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "There are some keys in that box.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "When something happens",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": [
            {
              "sentence": "We can also use  there is, there are to say when something happens.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "There is a concert tonight.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "There are a lot of storms in summer.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "A, some, any",
          "formula": "We often use  there is, there are + a, some, any.",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 3,
          "examples": []
        },
        {
          "title": "There is + singular / there are + plural",
          "formula": "We use there is + singular noun, and there are + plural noun.",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 4,
          "examples": [
            {
              "sentence": "There is a new teacher in the school.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "There are some problems that we need to solve.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "We use there is + a list of things if the first noun after there is is singular.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "In the room, there is a bed, a wardrobe and two chairs.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        }
      ]
    },
    {
      "level": "A1",
      "title": "There is, there are, there was, there were: Form",
      "slug": "a1-there-is-there-are-there-was-there-were-form",
      "order": 58,
      "chapter": "there and it",
      "description": "",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": [
        {
          "title": "Present and past",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "The past form of there is, there are is there was, there were.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "There is a car in the street. ⇒  There was a car in the street.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "There are some cars in the street. ⇒  There were some cars in the street.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Short forms",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": [
            {
              "sentence": "The short form of there is is there’s, but we don’t use a short form of there are. There’s is not used in short answers.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "There’s a new secretary in the office.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "There are two bathrooms in this house.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "There are no short forms for there was/there were.\n\nIn negative sentences, we often use the short forms there isn’t/there aren’t and there wasn’t/weren’t.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "There isn’t any bread left. We need to buy more.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "There aren’t any cookies in the jar.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        }
      ]
    },
    {
      "level": "A1",
      "title": "There or It",
      "slug": "a1-there-or-it",
      "order": 59,
      "chapter": "there and it",
      "description": "",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": []
    },
    {
      "level": "A1",
      "title": "There",
      "slug": "a1-there",
      "order": 60,
      "chapter": "there and it",
      "description": "We use there to say when or where something is. There are some dirty cups on the table. There is a party tomorrow. We use there to say that something exists or is happening. There is a problem. There was an accident. Note that we use there the first time we mention something. If we talk about the same thing again, we use it or they. There are some cups on the table. But they are dirty. There was an accident. It was horrible.",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": []
    },
    {
      "level": "A1",
      "title": "It",
      "slug": "a1-it",
      "order": 61,
      "chapter": "there and it",
      "description": "We use it to talk about something again in the conversation. There is a party tomorrow. It will be fantastic! We saw a snake in the forest. It was very big. We use it to talk about times and dates. It‘s my mum’s birthday today. Let’s go home. It‘s very late. It‘s four o’clock. We use it to talk about the weather. It‘s very windy. It‘s a nice day. It rained a lot yesterday. It‘s four degrees. We use it to talk about distance. How far is it? It‘s not very far. It‘s a long way to the nearest petrol station. It‘s 2 kilometres from the hotel to the station. ❗ Note that we use far in negative sentences and questions, and we use a long way in affirmative sentences. We use it’s + adjective + to-infinitive. It’s nice to see you again. It was difficult to find the hotel.",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": []
    },
    {
      "level": "A1",
      "title": "Be careful with these common mistakes!",
      "slug": "a1-be-careful-with-these-common-mistakes",
      "order": 62,
      "chapter": "there and it",
      "description": "I think the worst part of the exam it’s speaking. I think the worst part of the exam is speaking. We do NOT use it when the subject of the verb is in the sentence. In the sentence above, the subject of is is ‘the worst part of the exam’. I love their music. Is fantastic! I love their music. It’s fantastic! Don’t forget to use it when you mention something again in the conversation.",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": []
    },
    {
      "level": "A1",
      "title": "The difference between this and it",
      "slug": "a1-the-difference-between-this-and-it",
      "order": 63,
      "chapter": "there and it",
      "description": "You can use this to talk about something near you. It is like pointing your finger at something in front of you. This cat is cute. (The cat is right there with you.) This is my house. (The house in front of you.) I think this jacket is perfect for you. You can also use this to introduce a person to another one or to introduce yourself on a phone call. This is my brother John. Hello, this is Linda. (On the phone) The plural form of this is these. These are my brothers, John and Edward.",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": [
        {
          "title": "To talk about something again",
          "formula": "",
          "explanation": "We use it to talk about something that we mentioned, or that is known. It is a pronoun, like he or she, but we use he or she to talk about people, and we use it to talk about objects or animals. There was a storm, and they cancelled the concert. It was a disaster. (It refers to the storm and the cancelling of the concert)",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "This cat is cute. It is sleeping.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "This is my house. I bought it last year.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Apart from objects or animals, we can also use it to refer to a situation or idea mentioned before.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Times, dates, weather, distance",
          "formula": "",
          "explanation": "“What day is it?” “It‘s Tuesday.”",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": [
            {
              "sentence": "It is used to talk about times, dates, weather, and distances.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "It‘s very late.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "It was sunny yesterday.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "It‘s not very far from here.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "It’s + adjective + to-infinitive",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 3,
          "examples": [
            {
              "sentence": "It‘s nice to see you again.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "It‘s easy to get lost in this part of the city.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "It’s + adjective + that…",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 4,
          "examples": [
            {
              "sentence": "It‘s important that you learn this.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        }
      ]
    },
    {
      "level": "A1",
      "title": "Adjectives in English – grammar chart",
      "slug": "a1-adjectives-in-english-grammar-chart",
      "order": 64,
      "chapter": "Adjectives and adverbs",
      "description": "",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "🎨",
      "rules": [
        {
          "title": "Adjective + noun",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "When we use adjectives with a noun in English, the adjectives go before the noun.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "It’s an expensive guitar.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "It’s a guitar expensive.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "She has a new car.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "She has a car new.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Am/is/are + adjective",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": [
            {
              "sentence": "We can also use adjectives without a noun after the verb be.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "This guitar is expensive.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Her car is new.",
