      "title": "Can, can’t: Form",
      "slug": "a1-can-cant-form",
      "order": 25,
      "chapter": "Modals, the imperative, etc .",
      "description": "",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📚",
      "rules": [
        {
          "title": "Infinitive without to",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "We use can + infinitive without to.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I can swim.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I can to swim.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "We can’t come.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "We can’t to come.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Don’t use -s after he/she/it",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": [
            {
              "sentence": "We don’t add -s after he/she/it. We use can for all persons.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "He can swim.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "He cans swim.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Don’t use do/don’t",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 3,
          "examples": [
            {
              "sentence": "Can is an auxiliary verb and has a negative and interrogative form. We don’t use do/don’t to make questions and negatives.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Can you swim?",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Do you can swim?",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "He can’t swim.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "He don’t can swim.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        }
      ]
    },
