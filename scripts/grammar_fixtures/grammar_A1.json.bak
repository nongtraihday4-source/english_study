        {
          "title": "No positive short forms",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": [
            {
              "sentence": "The negative short forms of was not and were not are wasn’t and weren’t, but there are no short forms of was and were in affirmative sentences.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Tom was tired, but Susan wasn’t very tired.",
              "translation": "",
              "context": "",
