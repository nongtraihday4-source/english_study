              "sentence": "I don’t watch TV.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Names of languages and school subjects",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 5,
          "examples": [
            {
              "sentence": "We do not use an article before the names of languages and school subjects.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "He doesn’t speak English.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I study biology.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Next, last",
          "formula": "",
          "explanation": "❗ Compare: We really loved London. The last day we were really sad. (The last day= the last day of that trip. NOT the day before now)",
          "memory_hook": "",
          "is_exception": false,
          "order": 6,
          "examples": [
            {
              "sentence": "We do not use an article before next and last + time expression (when they mean before or after now).",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "The meeting is next Thursday.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I saw him last week.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Last year we spent one week in London (Last year= the year before now).",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        }
      ]
