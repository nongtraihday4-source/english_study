    {
      "level": "A1",
      "title": "Uncountable nouns",
      "slug": "a1-uncountable-nouns",
      "order": 49,
      "chapter": "Articles, nouns, pronouns, and determiners.",
      "description": "Uncountable nouns are nouns that we cannot count: money, milk, rain, etc. We cannot say one money, two moneys, etc. So, uncountable nouns do not have a plural form; they only have a singular form: money, milk, rain, etc.",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📦",
      "rules": [
        {
          "title": "Do NOT use a/an",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "We cannot use a/an + uncountable noun. A/an means ‘one’, and we cannot count uncountable nouns.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I need a money.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I need money.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "We need to buy a sugar.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "We need to buy sugar.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Types of words that are uncountable",
          "formula": "",
          "explanation": "Some types of words that are typically uncountable are: Food, drinks and liquids: cheese, bread, pasta, coffee, milk, petrol, fuel, etc.\n\nMaterials: iron, wood, metal, paper, plastic, etc.\n\nAbstract ideas and feelings: information, advice, strength, time, love, excitement, etc.\n\nIllnesses: diabetes, Alzheimer’s, cancer, etc.\n\nLanguages: English, French, Spanish, etc.",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": []
        },
        {
          "title": "Uncountable in English but not in other languages",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 3,
          "examples": [
            {
              "sentence": "Some nouns are uncountable in English, but they are countable in other languages. Some of them are advice, news (it ends in -s, but it’s a singular word), furniture, luggage, baggage, bread, cheese, toast, etc.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        }
      ]
    },
