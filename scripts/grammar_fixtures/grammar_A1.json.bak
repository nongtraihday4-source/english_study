    {
      "level": "A1",
      "title": "Use no article",
      "slug": "a1-use-no-article",
      "order": 42,
      "chapter": "Articles, nouns, pronouns, and determiners.",
      "description": "Compare: I love music. (=Music in general.) I loved the music at the party. (=Specific music.) Children are often difficult. (=Children in general.) They are a nice family. The children are very funny",
      "analogy": "",
      "real_world_use": "",
      "memory_hook": "",
      "icon": "📌",
      "rules": [
        {
          "title": "General meaning",
          "formula": "",
          "explanation": "Compare: I love music. (=Music in general.) I loved the music at the party. (=Specific music.) Children are often difficult. (=Children in general.) They are a nice family. The children are very funny. (=The children in that family.)",
          "memory_hook": "",
          "is_exception": false,
          "order": 1,
          "examples": [
            {
              "sentence": "We do not use an article before plural or uncountable nouns to talk about something in general.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I don’t drink milk.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Women drive more cautiously than men.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Meals",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 2,
          "examples": [
            {
              "sentence": "We do not use an article before the names of meals: breakfast, lunch, or dinner.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Dinner is served at 8.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I always have breakfast with my children.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "Years, months and days",
          "formula": "",
          "explanation": "",
          "memory_hook": "",
          "is_exception": false,
          "order": 3,
          "examples": [
            {
              "sentence": "We do not use an article before names of years, months and days of the week.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "Friday is my favourite day of the week.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
            {
              "sentence": "I think 2020 will be an excellent year.",
              "translation": "",
              "context": "",
              "highlight": ""
            }
          ]
        },
        {
          "title": "TV",
          "formula": "",
          "explanation": "We do not use an article with TV (when used as a broadcasting service, NOT as an appliance) ❗ But: Turn off the TV. I’ve bought a new TV.",
          "memory_hook": "",
          "is_exception": false,
          "order": 4,
          "examples": [
            {
              "sentence": "I saw it on TV.",
              "translation": "",
              "context": "",
              "highlight": ""
            },
